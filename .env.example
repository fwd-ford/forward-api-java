# forward-api-java environment template
# Copie para .env e preencha. NUNCA commite .env com valores reais.
# Copy to .env and fill in. NEVER commit .env with real values.

# =============================================================================
# Server
# =============================================================================

# HTTP port the Spring Boot app listens on.
# Default: 8080 (native dev). The forward-infra docker compose publishes this
# container on host port 18080 so the native server can keep 8080 free.
PORT=8080

# Runtime environment: development | staging | production.
# Affects logging format (logback-spring.xml) and other defaults.
ENV=development

# Root log level: TRACE | DEBUG | INFO | WARN | ERROR.
LOG_LEVEL=INFO

# =============================================================================
# Database (PostgreSQL)
# =============================================================================

# JDBC connection string. For local docker compose use the value below.
# For Supabase use the pooler URL (port 6543) with sslmode=require.
# Pooler URL example (transaction mode, recommended for serverless):
#   jdbc:postgresql://aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=jdbc:postgresql://localhost:5432/forward?sslmode=disable

DATABASE_USER=forward
DATABASE_PASSWORD=forward_dev

# =============================================================================
# Auth (Supabase JWT)
# =============================================================================
# A API aceita dois caminhos de validação JWT:
#   1) HS256 com segredo compartilhado (SUPABASE_JWT_SECRET).
#   2) JWKS assimétrico (SUPABASE_JWKS_URL), preferido em produção.
# Defina pelo menos um. Se ambos estiverem presentes, o AlgAwareJwtValidator
# escolhe o validador correto pelo header `alg` do token.
#
# Como obter (Supabase Dashboard):
#   Settings > API > "JWT Settings" > "JWT Secret" (para HS256)
#   Settings > API > "JWKS URL" (para asymmetric)
#   Settings > API > "URL" (issuer base, usado em SUPABASE_JWT_ISSUER)

SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=

# Server-to-server pre-shared key used by N8N, cron jobs and CI smoke tests.
# Sent via the `X-API-Key` header. Skip JWT path when this matches.
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# =============================================================================
# CORS & rate limiting
# =============================================================================

# Comma-separated allowlist. Wildcard `*` is rejected on purpose.
# Local mobile dev: http://localhost:8081 (Expo dev server)
# Local web dev:   http://localhost:3000, http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Bucket4j sliding-window rate limit per (IP + subject) tuple.
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=1m

# Maximum request body size in bytes (also enforced by Tomcat at 1MB).
MAX_BODY_BYTES=1048576
